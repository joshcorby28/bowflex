{%- if card_product and card_product != empty -%}

<div class="hero-product-card">

  <div class="hero-product-card__content">

    {% if card_product.tags contains 'new' %}
      <span class="hero-product-card__badge">New</span>
    {% endif %}

    <h2 class="hero-product-card__title">
      <a href="{{ card_product.url }}">
        {{ card_product.title }}
      </a>
    </h2>

    {% if card_product.metafields.custom.subtitle %}
      <p class="hero-product-card__subtitle">
        {{ card_product.metafields.custom.subtitle }}
      </p>
    {% endif %}

    <div class="hero-product-card__features">
      <span>📱 JRNY App</span>
      <span>⌚ Connect to Apple Watch</span>
    </div>

    <div class="hero-product-card__price">

      {% if card_product.compare_at_price > card_product.price %}
        <span class="price-old">
          {{ card_product.compare_at_price | money }}
        </span>
      {% endif %}

      <span class="price-new">
        {{ card_product.price | money }}
      </span>

    </div>

    <a href="{{ card_product.url }}" class="hero-product-card__button">
      Buy Now
    </a>

  </div>


  <div class="hero-product-card__image">

    <a href="{{ card_product.url }}">
      {% if card_product.featured_media %}
        {{
          card_product.featured_media
          | image_url: width: 1200
          | image_tag:
          loading: 'lazy',
          widths: '400,600,800,1000,1200',
          class: 'hero-product-img'
        }}
      {% endif %}
    </a>

  </div>

</div>

{%- endif -%}

<style>
    .hero-product-card{
display:flex;
align-items:center;
justify-content:space-between;
background:#f6f6f6;
padding:80px;
gap:60px;
border-radius:8px;
}

.hero-product-card__content{
max-width:500px;
}

.hero-product-card__badge{
background:#6dd26d;
color:#000;
font-size:12px;
padding:4px 10px;
border-radius:20px;
display:inline-block;
margin-bottom:15px;
}

.hero-product-card__title{
font-size:22px;
font-weight:700;
margin:0 0 10px;
}

.hero-product-card__title a{
text-decoration:none;
color:#000;
}

.hero-product-card__subtitle{
color:#555;
margin-bottom:20px;
}

.hero-product-card__features{
display:flex;
flex-direction:column;
gap:8px;
font-size:14px;
margin-bottom:20px;
}

.hero-product-card__price{
margin:25px 0;
}

.price-old{
text-decoration:line-through;
color:#888;
margin-right:10px;
font-size:18px;
}

.price-new{
font-size:22px;
font-weight:700;
color:#4041f1;
}

.hero-product-card__button{
display:inline-block;
background:#000;
color:#fff;
padding:14px 26px;
text-decoration:none;
border-radius:4px;
font-weight:600;
margin-top:10px;
}

.hero-product-card__button:hover{
opacity:.85;
}

.hero-product-card__image img{
max-width:550px;
width:100%;
height: auto;
}

@media(max-width:900px){

.hero-product-card{
flex-direction:column;
text-align:center;
padding:40px;
}

.hero-product-card__image img{
max-width:100%;
}

}
</style>