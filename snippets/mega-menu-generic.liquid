{%- liquid
  assign cta_label = cta_text
  if cta_label == blank
    assign cta_label = 'Shop ' | append: menu_link.title
  endif

  assign cta_href = cta_url
  if cta_href == blank
    assign cta_href = menu_link.url
  endif
-%}

<li class="mega-products">
  {%- if product_1 != blank -%}
    {%- assign p = all_products[product_1] -%}
    {%- if p != blank -%}
      <a href="{{ p.url }}" class="mega-product-card">
        <div class="mega-product-image">
          {{ p.featured_image | image_url: width: 160 | image_tag }}
        </div>
        <div class="mega-product-info">
          <div class="mega-product-title">{{ p.title }}</div>
          <div class="mega-product-subtitle">{{ p.metafields.custom.short_text }}</div>
        </div>
        {%- if p.tags contains 'New' -%}
          <span class="mega-badge">New</span>
        {%- endif -%}
      </a>
    {%- endif -%}
  {%- endif -%}

  {%- if product_2 != blank -%}
    {%- assign p = all_products[product_2] -%}
