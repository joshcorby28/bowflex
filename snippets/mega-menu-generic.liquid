      <a href="{{ p.url }}" class="mega-product-card">
        <div class="mega-product-image">
          {{ p.featured_image | image_url: width: 160 | image_tag }}
        </div>
        <div class="mega-product-info">
          <div class="mega-product-title">{{ p.title }}</div>
          <div class="mega-product-subtitle">{{ p.metafields.custom.short_text }}</div>
        </div>
        {%- if p.tags contains 'New' -%}
          <span class="mega-badge">New</span>
        {%- endif -%}
      </a>
    {%- endif -%}
  {%- endif -%}

  {%- if product_4 != blank -%}
    {%- assign p = all_products[product_4] -%}
    {%- if p != blank -%}
      <a href="{{ p.url }}" class="mega-product-card">
        <div class="mega-product-image">
          {{ p.featured_image | image_url: width: 160 | image_tag }}
        </div>
        <div class="mega-product-info">
          <div class="mega-product-title">{{ p.title }}</div>
          <div class="mega-product-subtitle">{{ p.metafields.custom.short_text }}</div>
        </div>
        {%- if p.tags contains 'New' -%}
          <span class="mega-badge">New</span>
        {%- endif -%}
      </a>
    {%- endif -%}
  {%- endif -%}

  {%- if product_5 != blank -%}
    {%- assign p = all_products[product_5] -%}
    {%- if p != blank -%}
      <a href="{{ p.url }}" class="mega-product-card">
        <div class="mega-product-image">
          {{ p.featured_image | image_url: width: 160 | image_tag }}
        </div>
        <div class="mega-product-info">
          <div class="mega-product-title">{{ p.title }}</div>
          <div class="mega-product-subtitle">{{ p.metafields.custom.short_text }}</div>
        </div>
        {%- if p.tags contains 'New' -%}
          <span class="mega-badge">New</span>
        {%- endif -%}
      </a>
    {%- endif -%}
  {%- endif -%}

  <div class="mega-menu-actions">
    <a href="{{ cta_href }}" class="global-black-button">{{ cta_label }}</a>
    {%- unless hide_compare_link -%}
      <a href="/pages/compare-{{ menu_link.handle }}" class="mega-menu-compare-link">Compare {{ menu_link.title }}</a>
    {%- endunless -%}
  </div>
</li>

<style>
details[open] > .header__submenu {
  width: 360px;
}

.mega-products {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.mega-product-card {
  background: #efefef;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  text-decoration: none;
  border-radius: 3px;
  gap: 10px;
}

.mega-product-image img {
  max-width: 80px;
  height: 80px;
  background-blend-mode: multiply;
  mix-blend-mode: multiply;
}

.mega-product-title {
  text-decoration: none;
  color: #1b1b1b;
  font-weight: 700;
}

.mega-menu-compare-link {
  display: block;
  text-align: center;
  font-size: 14px;
  color: #1b1b1b;
  margin-top: 10px;
  text-decoration: underline;
  padding-top: 2px;
  font-weight: 600;
}
</style>
