                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

                {% if total_savings > 0 %}
                  <div class="you-saved">
                    <div class="hr-left"></div>

                    <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512" height="1em" width="1em">
                      <path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"></path>
                    </svg>

                    You Saved {{ total_savings | money }}

                    <div class="hr-right"></div>
                  </div>


                    <style>
                      .you-saved {
                        display: flex;
                        align-items: center;
                        gap: 10px;
                      }

                      .hr-left,
                      .hr-right {
                        flex: 1;
                        display:flex;
                        height: 1px;
                        background-color: #e5e5e5; /* soft grey */
                      }

                      .hr-left {
                        margin-right: 0.5rem;
                      }

                      .hr-right {
                        margin-left: 0.5rem;
                      }
                    </style>

                {% endif %}
              <div class="cart__ctas">
                <noscript>
                  <button type="submit" class="cart__update-button button button--secondary" form="cart">
                    {{ 'sections.cart.update' | t }}
                  </button>
                </noscript>

                <button
                  type="submit"
                  id="checkout"
                  class="global-blue-button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
                >
                  <span class="content">Secure Checkout</span>
                  <span class="icon"><i class="fa fa-shopping-bag" aria-hidden="true"></i></span>
                </button>
                {%- if additional_checkout_buttons -%}
                  <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                    {{ content_for_additional_checkout_buttons }}
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>

        {% comment %}
          <div class="smarte-cart-tabs">
            <div class="accordion">
              <div class="accordion-item">
                <button id="accordion-button-1" aria-expanded="false">
                  <span class="accordion-title">Do you have a discount code?</span
                  ><span class="icon" aria-hidden="true"></span>
                </button>
                <div class="accordion-content">
                  <form action="/cart" class="discount-code-tab" method="post">
                    <input type="text" name="discount" id="cart-discount-code" placeholder="Enter discount code">
                    <button type="submit" class="cart-discount-code-btn">Apply</button>
                  </form>
                </div>
              </div>
              <div class="accordion-item">
                <button id="accordion-button-2" aria-expanded="false">
                  <span class="accordion-title">Shipping and Delivery Information</span
                  ><span class="icon" aria-hidden="true"></span>
                </button>
                <div class="accordion-content">
                  <span> {{ section.settings['delivery-text'] }}</span>
                </div>
              </div>
            </div>
          </div>
        {% endcomment %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const expandButtons = document.querySelectorAll('.expand-button');
    expandButtons.forEach(function (button) {
      button.addEventListener('click', function () {
        const parentSection = this.closest('.smarte-payment-expandable-section');
        parentSection.classList.toggle('expanded');

        if (parentSection.classList.contains('expanded')) {
          this.textContent = 'Hide other payment options';
        } else {
          this.textContent = 'View other payment options';
        }
      });
    });
  });
</script>

<script>
  const items = document.querySelectorAll('.accordion button');

  function toggleAccordion() {
    const itemToggle = this.getAttribute('aria-expanded');

    for (let i = 0; i < items.length; i++) {
      items[i].setAttribute('aria-expanded', 'false');
    }

    if (itemToggle === 'false') {
      this.setAttribute('aria-expanded', 'true');
    }
  }

  items.forEach((item) => item.addEventListener('click', toggleAccordion));
</script>

<script src="//cdnjs.cloudflare.com/ajax/libs/datejs/1.0/date.min.js" async></script>

<script>
  function calculateDeliveryDate() {
    var deliveryDate = Date.today().addDays(1);
    if (deliveryDate.is().saturday() || deliveryDate.is().sunday()) {
      deliveryDate = deliveryDate.next().monday();
    }

    function getDayWithSuffix(day) {
      if (day > 3 && day < 21) return day + 'th';
      switch (day % 10) {
        case 1:
          return day + 'st';
        case 2:
          return day + 'nd';
        case 3:
          return day + 'rd';
        default:
          return day + 'th';
      }
    }

    var formattedDate = getDayWithSuffix(deliveryDate.getDate()) + ' ' + deliveryDate.toString('MMM');

    var dispatchDates = document.querySelectorAll('.dispatch-date');
    dispatchDates.forEach(function (element) {
      element.innerHTML = formattedDate;
    });
  }

  window.addEventListener('load', function () {
    if (typeof Date !== 'undefined') {
      calculateDeliveryDate();
    } else {
      document.querySelector('script[src*="date.min.js"]').addEventListener('load', calculateDeliveryDate);
    }
  });
</script>

{% schema %}
