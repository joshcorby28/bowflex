      "default": "Write your story here."
    },
    {
      "type": "textarea",
      "id": "story-name",
      "label": "Story Name",
      "default": "Verified Buyer"
    },
    {
      "type": "header",
      "content": "Promise Section"
    },
    {
      "type": "paragraph",
      "content": "Smarte Promise"
    },
    {
      "type": "text",
      "id": "trust-number",
      "default": "14,800+",
      "label": "Reviews number"
