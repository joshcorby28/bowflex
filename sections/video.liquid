<style>
  .smarte-video-hero .video-section {
  position: relative;
  display: flex;
  overflow: hidden;
  max-height: 700px;
  z-index: 0;
}
.smarte-video-hero .video-section .desktop-video {
  width: 100%;
  height: fit-content;
}
.smarte-video-hero .video-section .mobile-video {
  display: none;
  width: 100%;
  height: 100vh;
}
.smarte-video-hero .video-section video {
  width: 100%;
  height: 100%;
}
.smarte-video-hero .video-section img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.smarte-video-hero .video-section .full-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 0;
}
.smarte-video-hero .video-section .hero-overlay-wrapper {
  position: absolute;
  top: 0;
  display: flex;
  height: 100%;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  flex-wrap: nowrap;
  z-index: 1;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.top-left {
  align-items: flex-start;
  justify-content: flex-start;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.top-center {
  align-items: flex-start;
  justify-content: center;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.top-right {
  align-items: flex-start;
  justify-content: flex-end;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.middle-left {
  align-items: center;
  justify-content: flex-start;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.middle-center {
  align-items: center;
  justify-content: center;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.middle-right {
  align-items: center;
  justify-content: flex-end;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.bottom-left {
  align-items: flex-end;
  justify-content: flex-start;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.bottom-center {
  align-items: flex-end;
  justify-content: center;
}
.smarte-video-hero .video-section .hero-overlay-wrapper.bottom-right {
