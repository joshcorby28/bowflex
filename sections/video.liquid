          "id": "stand_out_text",
          "label": "Stand Out Text"
        },

        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "color",
          "id": "heading_text_color",
          "label": "Heading text",
          "default": "#000000"
        },
        {
          "type": "header",
          "content": "Text Settings"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "color",
