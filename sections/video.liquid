{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'smarte-video-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  }

  .desktop-video,
  .mobile-video {
    position: relative;
    overflow: hidden;
  }
{%- endstyle -%}

<div class="smarte-video-hero" data-no-video-mobile="{{ section.settings.no_video_mobile }}">
  <div
    class="video-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding"
  >
<div class="desktop-video">
  {% assign poster_desktop = section.settings.poster_desktop | img_url: 'master' %}

  {% if section.settings.video %}
    {{
      section.settings.video
      | video_tag: autoplay: true, loop: true, muted: true, controls: false, poster: poster_desktop
    }}
  {% elsif section.settings.poster_desktop %}
    {{
      section.settings.poster_desktop
      | img_url: 'master'
      | img_tag: alt: 'Hero poster'
    }}
  {% endif %}
</div>

    <div
      class="mobile-video"
      data-render-mode="{% if section.settings.no_video_mobile %}poster-only{% else %}video{% endif %}"
    >
      {% assign poster_mobile = section.settings.poster_mobile %}
      {% if section.settings.no_video_mobile %}
        {% if poster_mobile %}
          {{
            poster_mobile
            | img_url: 'master'
            | img_tag: alt: section.settings.video_mobile.alt
            | default: 'Video poster'
          }}
        {% endif %}
      {% else %}
        {% assign poster_mobile_src = poster_mobile | img_url: 'master' %}
        {{
          section.settings.video_mobile
          | video_tag: autoplay: true, loop: true, muted: true, controls: false, poster: poster_mobile_src
        }}
      {% endif %}
    </div>

    {% if section.settings.show_overlay %}
      <div
        class="full-overlay"
        style="background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
      ></div>
    {% endif %}

    <div class="hero-overlay-wrapper  page-width {{ section.settings.horizontal_alignment }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'text' -%}
            {% if block.settings['show-quotes'] %}
              {%- style -%}
                .quote-image-block::before {
                  content: '"';
                  color: #fff;
                  margin-left: -40px;
                }

                .quote-image-block::after {
                  content: '"';
                  color: #fff;
                }
              {%- endstyle -%}
            {% endif %}
            <div
              class="hero-overlay {{ block.id }}"
              style="border-radius: {{ block.settings.border_radius }}px;{% if block.settings.backdrop_filter == true %}backdrop-filter: blur(15px);{% endif %}"
            >
              {% if block.settings.show_review %}
                <div class="hero-tp-widget" data-show-review="{{ block.settings.show_review }}">
                  {% render 'smarte-tp-widget-2025' %}
                </div>
              {% endif %}
              {% if block.settings.image_with_text_image %}
                <div style="margin:20px auto; text-align: center;" class="hero-trust">
                  {{ block.settings.image_with_text_image | img_url: width: 250 | img_tag }}
                </div>
              {% endif %}
              {% if block.settings.stand_out_text %}
                <div class="stand-out-text">{{ block.settings.stand_out_text }}</div>
              {% endif %}
              <div
                class="heading {% if block.settings['show-quotes'] %} quote-image-block {% endif %}"
                style="color: {{ block.settings.heading_text_color }}"
              >
                {{ block.settings.heading }}
              </div>
              <div class="text" style="color:{{ block.settings.body_text_color }} ">
                {{ block.settings.text }}
              </div>
              <div class="buttons">
                {% if block.settings.button_link_one %}
                  <a
                    href="{{ block.settings.button_link_one }}"
                    title="{{ block.settings.link_one_text }}"
                    class="btn-{{ block.settings.button_link_one_style }}"
                  >
                    {{ block.settings.link_one_text }}
                  </a>
                {% endif %}
                {% if block.settings.button_link_two %}
                  <a
                    class="{%  if block.settings.button_link_two %} mobile {% endif %} btn-{{ block.settings.button_link_two_style }}"
                    href="{{ block.settings.button_link_two }}"
                    title="{{ block.settings.link_two_text }}"
                  >
                    {{ block.settings.link_two_text }}
                  </a>
                {% endif %}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
