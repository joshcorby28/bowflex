          "label": "Body text",
          "default": "#000000"
        },
        {
          "type": "header",
          "content": "First Links Settings"
        },
        {
          "type": "url",
          "id": "button_link_one",
          "label": "First Button link"
        },
        {
          "type": "text",
          "id": "link_one_text",
          "label": "Link One Text"
        },
        {
          "type": "select",
          "id": "button_link_one_style",
          "label": "Button Style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            },
            {
              "value": "outline",
              "label": "Outline"
            }
          ],
          "default": "primary"
        },
        {
          "type": "header",
          "content": "Second Links Settings"
