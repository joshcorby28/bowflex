{%- liquid
  assign compare_collection = section.settings.collection
  assign product_limit = section.settings.products_to_show | default: 3
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .compare-products {
    background: {{ section.settings.section_background }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .compare-products__wrap {
    padding: 64px 20px;
  }

  #shopify-section-{{ section.id }} .compare-products__heading {
    margin: 0 0 8px;
    color: {{ section.settings.heading_color }};
    font-size: clamp(3rem, 4vw, 6rem);
    line-height: 1.02;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .compare-products__subheading {
    margin: 0 0 32px;
    color: {{ section.settings.text_color }};
    font-size: 1.6rem;
    line-height: 1.5;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .compare-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--compare-columns, 3), minmax(0, 1fr));
    border-left: 1px solid {{ section.settings.border_color }};
    border-top: 1px solid {{ section.settings.border_color }};
  }

  #shopify-section-{{ section.id }} .compare-products__card {
    min-width: 0;
    display: flex;
    flex-direction: column;
    border-right: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    background: {{ section.settings.card_background }};
  }

  #shopify-section-{{ section.id }} .compare-products__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: {{ section.settings.media_background }};
  }

  #shopify-section-{{ section.id }} .compare-products__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .compare-products__badge {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 18px;
    min-height: 36px;
    border-radius: 12px;
    background: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_text_color }};
    font-size: 1.8rem;
    line-height: 1;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .compare-products__badge--sale {
    font-style: italic;
  }

  #shopify-section-{{ section.id }} .compare-products__copy {
    padding: 20px 18px 0;
  }

  #shopify-section-{{ section.id }} .compare-products__title {
    margin: 0 0 6px;
    font-size: clamp(2.4rem, 2vw, 3.2rem);
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .compare-products__title a {
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .compare-products__description {
    margin: 0;
    color: {{ section.settings.muted_text_color }};
    font-size: 1.25rem;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .compare-products__price {
    padding: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    align-items: baseline;
    font-size: 1.25rem;
  }

  #shopify-section-{{ section.id }} .compare-products__price-current {
    color: {{ section.settings.price_color }};
    font-weight: 700;
    font-size: 2rem;
  }

  #shopify-section-{{ section.id }} .compare-products__price-compare {
    color: {{ section.settings.muted_text_color }};
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .compare-products__price-note {
    color: {{ section.settings.muted_text_color }};
  }

  #shopify-section-{{ section.id }} .compare-products__actions {
    padding: 0 18px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: space-between;
  }

  #shopify-section-{{ section.id }} .compare-products__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 12px 28px;
    flex: 1 1 auto;
    border-radius: 2px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    font-size: 1.8rem;
    line-height: 1;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .compare-products__link {
    color: {{ section.settings.link_color }};
    font-size: 1.25rem;
    text-decoration: underline;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .compare-products__features {
    margin: 0;
    padding: 0 18px 28px 38px;
    display: grid;
    gap: 12px;
    font-size: 1.25rem;
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .compare-products__empty {
    padding: 24px;
    border: 1px dashed {{ section.settings.border_color }};
    color: {{ section.settings.muted_text_color }};
    font-size: 1.25rem;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .compare-products__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .compare-products__wrap {
      padding: 44px 16px;
    }

    #shopify-section-{{ section.id }} .compare-products__actions {
      flex-direction: column;
      align-items: stretch;
    }

    #shopify-section-{{ section.id }} .compare-products__link {
      text-align: right;
    }
  }
{%- endstyle -%}

<section class="compare-products color-{{ section.settings.color_scheme }}">
  <div class="compare-products__wrap page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="compare-products__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="compare-products__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if compare_collection != blank and compare_collection.products_count > 0 -%}
      <div class="compare-products__grid" style="--compare-columns: {{ product_limit | at_most: compare_collection.products_count }};">
        {%- for product in compare_collection.products limit: product_limit -%}
          {%- assign product_index = forloop.index -%}
          {%- assign badge_text = '' -%}
          {%- assign badge_style = '' -%}

          {%- case product_index -%}
            {%- when 1 -%}
              {%- assign badge_text = section.settings.badge_text_1 -%}
              {%- assign badge_style = section.settings.badge_style_1 -%}
            {%- when 2 -%}
              {%- assign badge_text = section.settings.badge_text_2 -%}
              {%- assign badge_style = section.settings.badge_style_2 -%}
            {%- when 3 -%}
              {%- assign badge_text = section.settings.badge_text_3 -%}
              {%- assign badge_style = section.settings.badge_style_3 -%}
            {%- when 4 -%}
              {%- assign badge_text = section.settings.badge_text_4 -%}
              {%- assign badge_style = section.settings.badge_style_4 -%}
            {%- when 5 -%}
              {%- assign badge_text = section.settings.badge_text_5 -%}
              {%- assign badge_style = section.settings.badge_style_5 -%}
            {%- when 6 -%}
              {%- assign badge_text = section.settings.badge_text_6 -%}
              {%- assign badge_style = section.settings.badge_style_6 -%}
          {%- endcase -%}

          <article class="compare-products__card">
            <div class="compare-products__media">
              {%- if badge_text != blank -%}
                <span class="compare-products__badge{% if badge_style == 'sale' %} compare-products__badge--sale{% endif %}">{{ badge_text }}</span>
              {%- endif -%}

              {%- if product.featured_image != blank -%}
                <a href="{{ product.url }}">
                  {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.featured_image.alt | default: product.title, widths: '360,540,720,900' }}
                </a>
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="compare-products__copy">
              <h3 class="compare-products__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {%- if product.description != blank -%}
                <p class="compare-products__description">{{ product.description | strip_html | truncatewords: 12 }}</p>
              {%- endif -%}
            </div>

            <div class="compare-products__price">
              {%- if product.compare_at_price > product.price -%}
                <span class="compare-products__price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="compare-products__price-current">{{ product.price | money }}</span>
              {%- if section.settings.payment_note != blank -%}
                <span class="compare-products__price-note">{{ section.settings.payment_note }}</span>
              {%- endif -%}
            </div>

            <div class="compare-products__actions">
              <a class="compare-products__button" href="{{ product.url }}">{{ section.settings.button_label }}</a>
              <a class="compare-products__link" href="{{ product.url }}">{{ section.settings.link_label }} {{ product.title | remove: 'Treadmill' | strip }}</a>
            </div>

            <ul class="compare-products__features">
              {%- for block in section.blocks -%}
                {%- assign feature_text = '' -%}

                {%- case product_index -%}
                  {%- when 1 -%}
                    {%- assign feature_text = block.settings.product_1_text -%}
                  {%- when 2 -%}
                    {%- assign feature_text = block.settings.product_2_text -%}
                  {%- when 3 -%}
                    {%- assign feature_text = block.settings.product_3_text -%}
                  {%- when 4 -%}
                    {%- assign feature_text = block.settings.product_4_text -%}
                  {%- when 5 -%}
                    {%- assign feature_text = block.settings.product_5_text -%}
                  {%- when 6 -%}
                    {%- assign feature_text = block.settings.product_6_text -%}
                {%- endcase -%}

                {%- if feature_text != blank -%}
                  <li {{ block.shopify_attributes }}>{{ feature_text }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="compare-products__empty">Select a collection in the section settings to populate the compare section.</div>
    {%- endif -%}
  </div>
</section>

