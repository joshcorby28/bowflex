{%- liquid
  assign compare_collection = section.settings.collection
  assign product_limit = section.settings.products_to_show | default: 3
  assign overview_products = section.blocks | where: 'type', 'overview_product'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .compare-products {
    background: {{ section.settings.section_background }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .compare-products__wrap {
    padding: 64px 20px;
  }

  #shopify-section-{{ section.id }} .compare-products__heading {
    margin: 0 0 8px;
    color: {{ section.settings.heading_color }};
    font-size: clamp(3rem, 4vw, 6rem);
    line-height: 1.02;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .compare-products__subheading {
    margin: 0 0 32px;
    color: {{ section.settings.text_color }};
    font-size: 1.6rem;
    line-height: 1.5;
    text-align: {{ section.settings.heading_alignment }};
  }

  #shopify-section-{{ section.id }} .compare-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--compare-columns, 3), minmax(0, 1fr));
gap: 60px;
    border-bottom: none;
    border: none;
  }

  #shopify-section-{{ section.id }} .compare-products__overview {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .compare-products__overview-title {
    margin: 48px 0 24px;
    color: {{ section.settings.heading_color }};
    font-size: 2.2rem;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .compare-products__overview-grid {
    display: grid;
    grid-template-columns: repeat(var(--compare-columns, 3), minmax(0, 1fr));
gap: 60px;
    border-bottom: none;
    border: none;
  }

  #shopify-section-{{ section.id }} .compare-products__overview-col {
    border-right: 1px solid {{ section.settings.border_color }};
    padding: 0;
    background: {{ section.settings.card_background }};
  }

  #shopify-section-{{ section.id }} .compare-products__overview-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: {{ section.settings.media_background }};
  }

  #shopify-section-{{ section.id }} .compare-products__overview-media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .compare-products__video-play {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: rgba(0, 0, 0, 0.18);
    color: #ffffff;
    font-size: 1.4rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  #shopify-section-{{ section.id }} .compare-products__video-play-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255,255,255,0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .compare-products__video-play-icon svg {
    fill: #111111;
    width: 18px;
    height: 18px;
    margin-left: 3px;
  }

  #shopify-section-{{ section.id }} .compare-products__overview-features {
    margin: 0;
    padding: 20px 18px 24px 38px;
    display: grid;
    gap: 10px;
    font-size: 1.25rem;
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .compare-products__card {
    min-width: 0;
    display: flex;
    flex-direction: column;
    border-right: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    background: {{ section.settings.card_background }};
  }

  #shopify-section-{{ section.id }} .compare-products__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: {{ section.settings.media_background }};
  }

  #shopify-section-{{ section.id }} .compare-products__media img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .compare-products__badge {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 18px;
    min-height: 36px;
    border-radius: 12px;
    background: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_text_color }};
    font-size: 1.8rem;
    line-height: 1;
    font-weight: 600;
  }

  #shopify-section-{{ section.id }} .compare-products__badge--sale {
    font-style: italic;
  }

  #shopify-section-{{ section.id }} .compare-products__copy {
    padding: 20px 18px 0;
  }

  #shopify-section-{{ section.id }} .compare-products__title {
    margin: 0 0 6px;
    font-size: clamp(2.4rem, 2vw, 3.2rem);
    line-height: 1.1;
  }

  #shopify-section-{{ section.id }} .compare-products__title a {
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .compare-products__description {
    margin: 0;
    color: {{ section.settings.muted_text_color }};
    font-size: 1.25rem;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .compare-products__price {
    padding: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    align-items: baseline;
    font-size: 1.25rem;
  }

  #shopify-section-{{ section.id }} .compare-products__price-current {
    color: {{ section.settings.price_color }};
    font-weight: 700;
    font-size: 2rem;
  }

  #shopify-section-{{ section.id }} .compare-products__price-compare {
    color: {{ section.settings.muted_text_color }};
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .compare-products__price-note {
    color: {{ section.settings.muted_text_color }};
  }

  #shopify-section-{{ section.id }} .compare-products__actions {
    padding: 0 18px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: space-between;
  }

  #shopify-section-{{ section.id }} .compare-products__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 12px 28px;
    flex: 1 1 auto;
    border-radius: 2px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    text-decoration: none;
    font-size: 1.8rem;
    line-height: 1;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .compare-products__link {
    color: {{ section.settings.link_color }};
    font-size: 1.25rem;
    text-decoration: underline;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .compare-products__empty {
    padding: 24px;
    border: 1px dashed {{ section.settings.border_color }};
    color: {{ section.settings.muted_text_color }};
    font-size: 1.25rem;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .compare-products__grid,
    #shopify-section-{{ section.id }} .compare-products__overview-grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .compare-products__wrap {
      padding: 44px 16px;
    }

    #shopify-section-{{ section.id }} .compare-products__actions {
      flex-direction: column;
      align-items: stretch;
    }

    #shopify-section-{{ section.id }} .compare-products__link {
      text-align: right;
    }
  }
{%- endstyle -%}

<section class="compare-products color-{{ section.settings.color_scheme }}">
  <div class="compare-products__wrap page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="compare-products__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="compare-products__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if compare_collection != blank and compare_collection.products_count > 0 -%}
      {%- assign column_count = product_limit | at_most: compare_collection.products_count -%}

      {%- comment -%} Row 1: Product cards {%- endcomment -%}
      <div class="compare-products__grid" style="--compare-columns: {{ column_count }};">
        {%- for product in compare_collection.products limit: product_limit -%}
          {%- assign product_index = forloop.index -%}
          {%- assign badge_text = '' -%}
          {%- assign badge_style = '' -%}

          {%- case product_index -%}
            {%- when 1 -%}
              {%- assign badge_text = section.settings.badge_text_1 -%}
              {%- assign badge_style = section.settings.badge_style_1 -%}
            {%- when 2 -%}
              {%- assign badge_text = section.settings.badge_text_2 -%}
              {%- assign badge_style = section.settings.badge_style_2 -%}
            {%- when 3 -%}
              {%- assign badge_text = section.settings.badge_text_3 -%}
              {%- assign badge_style = section.settings.badge_style_3 -%}
            {%- when 4 -%}
              {%- assign badge_text = section.settings.badge_text_4 -%}
              {%- assign badge_style = section.settings.badge_style_4 -%}
            {%- when 5 -%}
              {%- assign badge_text = section.settings.badge_text_5 -%}
              {%- assign badge_style = section.settings.badge_style_5 -%}
            {%- when 6 -%}
              {%- assign badge_text = section.settings.badge_text_6 -%}
              {%- assign badge_style = section.settings.badge_style_6 -%}
          {%- endcase -%}

          <article class="compare-products__card">
            <div class="compare-products__media">
              {%- if badge_text != blank -%}
                <span class="compare-products__badge{% if badge_style == 'sale' %} compare-products__badge--sale{% endif %}">{{ badge_text }}</span>
              {%- endif -%}

              {%- if product.featured_image != blank -%}
                <a href="{{ product.url }}">
                  {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.featured_image.alt | default: product.title, widths: '360,540,720,900' }}
                </a>
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="compare-products__copy">
              <h3 class="compare-products__title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              {%- if product.description != blank -%}
                <p class="compare-products__description">{{ product.description | strip_html | truncatewords: 12 }}</p>
              {%- endif -%}
            </div>

            <div class="compare-products__price">
              {%- if product.compare_at_price > product.price -%}
                <span class="compare-products__price-compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="compare-products__price-current">{{ product.price | money }}</span>
              {%- if section.settings.payment_note != blank -%}
                <span class="compare-products__price-note">{{ section.settings.payment_note }}</span>
              {%- endif -%}
            </div>

            <div class="compare-products__actions">
              <a class="compare-products__button" href="{{ product.url }}">{{ section.settings.button_label }}</a>
              <a class="compare-products__link" href="{{ product.url }}">{{ section.settings.link_label }} {{ product.title | remove: 'Treadmill' | strip }}</a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- comment -%} Row 2: Overview {%- endcomment -%}
      {%- if overview_products.size > 0 -%}
        <div class="compare-products__overview">
          {%- if section.settings.overview_title != blank -%}
            <h3 class="compare-products__overview-title">{{ section.settings.overview_title }}</h3>
          {%- endif -%}

          <div class="compare-products__overview-grid" style="--compare-columns: {{ column_count }};">
            {%- for block in overview_products limit: product_limit -%}
              <div class="compare-products__overview-col" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank or block.settings.video_url != blank -%}
                  <div class="compare-products__overview-media">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360,540,720,900' }}
                    {%- endif -%}

                    {%- if block.settings.video_url != blank -%}
                      <a class="compare-products__video-play" href="{{ block.settings.video_url }}" target="_blank" rel="noopener">
                        <span class="compare-products__video-play-icon">
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                        </span>
                        Watch Video
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {%- assign has_features = false -%}
                {%- for i in (1..6) -%}
                  {%- assign feature_key = 'feature_' | append: i -%}
                  {%- if block.settings[feature_key] != blank -%}
                    {%- assign has_features = true -%}
                  {%- endif -%}
                {%- endfor -%}

                {%- if has_features -%}
                  <ul class="compare-products__overview-features">
                    {%- for i in (1..6) -%}
                      {%- assign feature_key = 'feature_' | append: i -%}
                      {%- if block.settings[feature_key] != blank -%}
                        <li>{{ block.settings[feature_key] }}</li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="compare-products__empty">Select a collection in the section settings to populate the compare section.</div>
    {%- endif -%}
  </div>
</section>

