<div class="cta-bar color-{{ section.settings.color_scheme }} gradient cta-bar--single-message">
  {%- if section.blocks.size > 0 and section.blocks.first.settings.text != blank -%}
    <div
      class="cta-bar__inner page-width flex items-center justify-between"
      role="region"
      aria-label="CTA Bar"
      {{ section.blocks.first.shopify_attributes }}
    >
        {% if section.settings.show_jrny_image %}
          <div class="cta-bar__img">
            <img 
              src="{{ section.blocks.first.settings.jrny_image | image_url }}" 
              alt="{{ section.blocks.first.settings.jrny_image.alt | escape }}"
            >
          </div>
        {% endif %}

        <!-- Message -->
        <p class="cta-bar__message h3">
          {{ section.blocks.first.settings.text | escape }}
        </p>

      <!-- Button if link exists -->
      {%- if section.blocks.first.settings.link != blank -%}
        <a
          href="{{ section.blocks.first.settings.link }}"
class="{% if section.blocks.first.settings.white-button %}global-white-button{% else %}global-black-button{% endif %}"
          role="button"
        >
          {{ section.blocks.first.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<style>
  .cta-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
  }

  .cta-bar__message {
    font-size: 24px;
  letter-spacing:0;
  }
</style>

{% schema %}
{
  "name": "CTA Bar",
  "max_blocks": 1,
  "class": "cta-bar-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },

    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "Show line separator"
    }
  ],
  "blocks": [
    {
      "type": "cta",
      "name": "CTA",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Add your call-to-action message",
          "label": "Text"
        },
            {
      "type": "checkbox",
      "id": "white-button",
      "default": false,
      "label": "Show White Button"
    },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Learn More"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CTA Bar",
      "blocks": [
        {
          "type": "cta"
        }
      ]
    }
  ]
}
{% endschema %}