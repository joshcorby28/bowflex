<div class="cta-bar color-{{ section.settings.color_scheme }} gradient cta-bar--single-message">
  {%- if section.blocks.size > 0 and section.blocks.first.settings.text != blank -%}
    <div
      class="cta-bar__inner page-width"
      role="region"
      aria-label="CTA Bar"
      {{ section.blocks.first.shopify_attributes }}
    >
      <div class="img-and-text">
        {% if section.blocks.first.settings.show-jrny-image != blank %}
          <div class="cta-bar__img">
            <img 
              src="{{ section.blocks.first.settings.show-jrny-image | image_url }}" 
              alt="{{ section.blocks.first.settings.show-jrny-image.alt | escape }}"
            >
          </div>
        {% endif %}

        <!-- Message -->
        <p class="cta-bar__message h3">
          {{ section.blocks.first.settings.text | escape }}
        </p>
      </div>

      <!-- Button if link exists -->
      {%- if section.blocks.first.settings.link != blank -%}
        <a
          href="{{ section.blocks.first.settings.link }}"
class="{% if section.blocks.first.settings.white-button %}global-white-button{% else %}global-black-button{% endif %}"
          role="button"
        >
          {{ section.blocks.first.settings.button_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<style>
  /* ===== DESKTOP ===== */
  .cta-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    min-height: 90px;
  }

  /* Force both sides to same height */
  .img-and-text {
    display: flex;
    align-items: center;
    gap: 10px;
    height: 44px;
  }

  .cta-bar__message {
    font-size: 24px;
    letter-spacing: 0;
    margin: 0;
    line-height: 44px; /* KEY: aligns with button height */
  }

  .img-and-text img {
    max-width: 130px;
    display: block;
  }

  .cta-bar__inner a.global-black-button,
  .cta-bar__inner a.global-white-button {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    line-height: 44px;
    margin: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  /* ===== MOBILE ===== */
  @media screen and (max-width: 749px) {
    .cta-bar__inner {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      text-align: center;
      padding: 24px 16px;
    }

    .img-and-text {
      justify-content: center;
      text-align: center;
      height: auto;
    }

    .cta-bar__message {
      font-size: 28px;
      line-height: 1.1;
      max-width: 280px;
    }

    .cta-bar__inner a {
      width: 100%;
      max-width: 280px;
    }
  }
</style>

{% schema %}
{
  "name": "CTA Bar",
  "max_blocks": 1,
  "class": "cta-bar-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },

    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "Show line separator"
    }
  ],
  "blocks": [
    {
      "type": "cta",
      "name": "CTA",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Add your call-to-action message",
          "label": "Text"
        },
            {
            "type": "image_picker",
            "id": "show-jrny-image",
            "label": "Show Jrny Image"
          },
            {
            "type": "checkbox",
            "id": "white-button",
            "default": false,
            "label": "Show White Button"
          },
        {
          "type": "url",
          "id": "link",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Learn More"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CTA Bar",
      "blocks": [
        {
          "type": "cta"
        }
      ]
    }
  ]
}
{% endschema %}