{%- style -%}
  .product-page-sections {
    background: #0f1014;
    color: #ffffff;
  }

  .product-page-sections .section-wrap {
    max-width: 1160px;
    margin: 0 auto;
    padding: 64px 20px;
  }

  .product-page-sections h2 {
    margin: 0 0 10px;
    color: inherit;
    font-size: clamp(2.6rem, 3vw, 4rem);
    line-height: 1.15;
  }

  .product-page-sections .section-subtitle {
    margin: 0 0 32px;
    opacity: 0.8;
    font-size: 1.4rem;
    line-height: 1.5;
  }

  .product-page-sections .media-placeholder,
  .product-page-sections .image-placeholder {
    border-radius: 12px;
    background: linear-gradient(135deg, #2d2f37 0%, #1d1f25 100%);
    border: 1px solid #3a3d48;
    min-height: 180px;
    display: grid;
    place-items: center;
    text-align: center;
    padding: 16px;
    color: #c6cad6;
    font-size: 1.35rem;
  }

  .product-page-sections .label-list {
    display: grid;
    gap: 10px;
  }

  .product-page-sections .label-row {
    background: #1f2128;
    border: 1px solid #313440;
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 1.3rem;
  }

  .product-page-sections .training-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: 300px 1fr;
    align-items: start;
  }

  .product-page-sections .training-grid .media-placeholder {
    min-height: 300px;
  }

  .product-page-sections .fit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .product-page-sections .fit-grid .image-placeholder {
    min-height: 320px;
  }

  .product-page-sections .app-row {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .product-page-sections .app-pill {
    background: #20232b;
    border: 1px solid #383c47;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 1.15rem;
  }

  .product-page-sections .light-panel {
    background: #f4f4f6;
    color: #121318;
  }

  .product-page-sections .light-panel .section-subtitle {
    color: #3e4350;
  }

  .product-page-sections .spec-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .product-page-sections .light-panel .image-placeholder {
    background: #e7e9ed;
    border-color: #d2d7df;
    color: #3f4654;
    min-height: 280px;
  }

  .product-page-sections .spec-list {
    display: grid;
    gap: 12px;
    font-size: 1.35rem;
  }

  .product-page-sections .spec-item {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid #d5dae2;
    padding-bottom: 10px;
  }

  .product-page-sections .accordion-list {
    border-top: 1px solid #d5dae2;
  }

  .product-page-sections .accordion-row {
    padding: 16px 0;
    border-bottom: 1px solid #d5dae2;
    display: flex;
    justify-content: space-between;
    font-size: 1.35rem;
  }

  .product-page-sections .membership-track {
    display: grid;
    grid-template-columns: repeat(4, minmax(180px, 1fr));
    gap: 16px;
  }

  .product-page-sections .membership-card {
    background: #171a21;
    border: 1px solid #2f3441;
    border-radius: 12px;
    overflow: hidden;
  }

  .product-page-sections .membership-card .image-placeholder {
    min-height: 170px;
    border: 0;
    border-bottom: 1px solid #2f3441;
    border-radius: 0;
  }

  .product-page-sections .membership-copy {
    padding: 14px;
  }

  .product-page-sections .membership-copy h3 {
    margin: 0 0 8px;
    font-size: 1.7rem;
    color: #fff;
  }

  .product-page-sections .membership-copy p {
    margin: 0;
    color: #c7cbd6;
    font-size: 1.3rem;
  }

  @media screen and (max-width: 989px) {
    .product-page-sections .training-grid,
    .product-page-sections .fit-grid,
    .product-page-sections .spec-grid {
      grid-template-columns: 1fr;
    }

    .product-page-sections .membership-track {
      grid-template-columns: repeat(2, minmax(160px, 1fr));
    }
  }
{%- endstyle -%}

<section class="product-page-sections color-{{ section.settings.dark_color_scheme }}">
  <div class="section-wrap">
    <h2>{{ section.settings.training_heading }}</h2>
    <p class="section-subtitle">{{ section.settings.training_subheading }}</p>

    <div class="training-grid">
      <div class="label-list">
        <div class="label-row">Explore entertainment</div>
        <div class="label-row">Go further with JRNY</div>
      </div>
      <div class="media-placeholder">
        Video / media area placeholder<br>
        (dummy media)
      </div>
    </div>
  </div>

  <div class="section-wrap">
    <h2>{{ section.settings.fitness_heading }}</h2>
    <p class="section-subtitle">{{ section.settings.fitness_subheading }}</p>

    <div class="fit-grid">
      <div>
        <div class="image-placeholder">Lifestyle image placeholder</div>
        <div class="app-row">
          <span class="app-pill">Apple Watch</span>
          <span class="app-pill">Galaxy Watch</span>
          <span class="app-pill">Connectivity</span>
        </div>
      </div>
      <div>
        <div class="image-placeholder">Touchscreen + apps placeholder</div>
        <div class="app-row">
          <span class="app-pill">Netflix</span>
          <span class="app-pill">YouTube</span>
          <span class="app-pill">Spotify</span>
          <span class="app-pill">Prime Video</span>
          <span class="app-pill">Disney+</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="product-page-sections light-panel color-{{ section.settings.light_color_scheme }}">
  <div class="section-wrap">
    <h2>{{ section.settings.specs_heading }}</h2>
    <p class="section-subtitle">Dummy values shown for layout only.</p>

    <div class="spec-grid">
      <div class="image-placeholder">Open position image</div>
      <div class="image-placeholder">Folded position image</div>
      <div class="spec-list">
        <div class="spec-item"><strong>Dimensions</strong><span>72” L × 36” W × 60” H</span></div>
        <div class="spec-item"><strong>Display</strong><span>16” HD touchscreen</span></div>
        <div class="spec-item"><strong>Product Weight</strong><span>293 lbs</span></div>
        <div class="spec-item"><strong>User Height</strong><span>4’7” – 6’6”</span></div>
        <div class="spec-item"><strong>Max User Weight</strong><span>375 lbs</span></div>
        <div class="spec-item"><strong>Warranty</strong><span>Frame: Lifetime</span></div>
      </div>
    </div>

    <div class="accordion-list" role="list">
      <div class="accordion-row" role="listitem"><span>Console</span><span>+</span></div>
      <div class="accordion-row" role="listitem"><span>Deck</span><span>+</span></div>
      <div class="accordion-row" role="listitem"><span>Drive System</span><span>+</span></div>
      <div class="accordion-row" role="listitem"><span>Frame</span><span>+</span></div>
      <div class="accordion-row" role="listitem"><span>Technical Specs</span><span>+</span></div>
    </div>
  </div>
</section>

<section class="product-page-sections color-{{ section.settings.dark_color_scheme }}">
  <div class="section-wrap">
    <h2>{{ section.settings.membership_heading }}</h2>
    <p class="section-subtitle">{{ section.settings.membership_subheading }}</p>

    <div class="membership-track">
      <article class="membership-card">
        <div class="image-placeholder">Card image 1</div>
        <div class="membership-copy">
          <h3>Every day is different.</h3>
          <p>Dummy membership benefit text for adaptive workouts and routines.</p>
        </div>
      </article>
      <article class="membership-card">
        <div class="image-placeholder">Card image 2</div>
        <div class="membership-copy">
          <h3>Pick up the pace.</h3>
          <p>Placeholder coaching text with real-time encouragement concepts.</p>
        </div>
      </article>
      <article class="membership-card">
        <div class="image-placeholder">Card image 3</div>
        <div class="membership-copy">
          <h3>Roam if you want.</h3>
          <p>Dummy text describing scenic routes and virtual location workouts.</p>
        </div>
      </article>
      <article class="membership-card">
        <div class="image-placeholder">Card image 4</div>
        <div class="membership-copy">
          <h3>Train your way.</h3>
          <p>Placeholder copy for custom goals, milestones, and plans.</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product page sections",
  "settings": [
    {
      "type": "color_scheme",
      "id": "dark_color_scheme",
      "label": "Dark section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "light_color_scheme",
      "label": "Light section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "training_heading",
      "label": "Training heading",
      "default": "The ultimate training experience"
    },
    {
      "type": "text",
      "id": "training_subheading",
      "label": "Training subheading",
      "default": "Watch videos below to learn more."
    },
    {
      "type": "text",
      "id": "fitness_heading",
      "label": "Entertainment + fitness heading",
      "default": "Entertainment + fitness at your fingertips."
    },
    {
      "type": "text",
      "id": "fitness_subheading",
      "label": "Entertainment + fitness subheading",
      "default": "Dummy content to represent media and app integrations."
    },
    {
      "type": "text",
      "id": "specs_heading",
      "label": "Specs heading",
      "default": "Specs & Warranty"
    },
    {
      "type": "text",
      "id": "membership_heading",
      "label": "Membership heading",
      "default": "The JRNY adaptive fitness membership keeps you going."
    },
    {
      "type": "text",
      "id": "membership_subheading",
      "label": "Membership subheading",
      "default": "Dummy carousel cards for membership benefits."
    }
  ],
  "presets": [
    {
      "name": "Product page sections"
    }
  ]
}
{% endschema %}
