{%- liquid
  assign training_tabs = section.blocks | where: 'type', 'training_tab'
  assign spec_metrics = section.blocks | where: 'type', 'spec_metric'
  assign warranty_metrics = section.blocks | where: 'type', 'warranty_metric'
  assign accordion_rows = section.blocks | where: 'type', 'specs_accordion'
  assign jrny_slides = section.blocks | where: 'type', 'jrny_slide'
  assign app_icons = section.blocks | where: 'type', 'app_icon'
  assign fallback_accordion_titles = 'Console,Deck,Drive System,Frame,Technical Specs' | split: ','
  assign fallback_training_video_url = section.settings.fallback_training_video_url
  assign training_position = section.settings.training_position | default: 1 | plus: 0
  assign fitness_position = section.settings.fitness_position | default: 2 | plus: 0
  assign specs_position = section.settings.specs_position | default: 3 | plus: 0
  assign membership_position = section.settings.membership_position | default: 4 | plus: 0
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .pps {
    background: #0b0c11;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .pps__wrap {
    padding: 64px 20px;
  }

  #shopify-section-{{ section.id }} .pps:not(.pps__specs),
  #shopify-section-{{ section.id }} .pps__fitness,
  #shopify-section-{{ section.id }} .pps__jrny {
    color: #fff;
  }

  #shopify-section-{{ section.id }} .pps:not(.pps__specs) .pps__title,
  #shopify-section-{{ section.id }} .pps:not(.pps__specs) .pps__subtitle,
  #shopify-section-{{ section.id }} .pps:not(.pps__specs) h3,
  #shopify-section-{{ section.id }} .pps:not(.pps__specs) p,
  #shopify-section-{{ section.id }} .pps:not(.pps__specs) span {
    color: #fff;
  }

  #shopify-section-{{ section.id }} .pps__title {
    margin: 0 0 8px;
    color: inherit;
    font-size: clamp(2.8rem, 3vw, 4.2rem);
    line-height: 1.12;
    font-weight:500;
    max-width:1000px;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .pps__subtitle {
    margin: 0 0 26px;
    opacity: 0.88;
    font-size: 1.35rem;
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .pps__media-shell,
  #shopify-section-{{ section.id }} .pps__image-shell {
    border-radius: 4px;
    min-height: 220px;
    display: grid;
    place-items: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .pps__media-shell iframe,
  #shopify-section-{{ section.id }} .pps__media-shell video,
  #shopify-section-{{ section.id }} .pps__media-shell img,
  #shopify-section-{{ section.id }} .pps__image-shell img,
  #shopify-section-{{ section.id }} .pps__slide-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 2px;
  }

  #shopify-section-{{ section.id }} .pps__training {
    display: grid;
    grid-template-columns: minmax(230px, 300px) 1fr;
    gap: 14px;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .pps__training-tabs {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  #shopify-section-{{ section.id }} .pps__tab {
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.07);
    color: #fff;
    text-align: left;
    padding: 0;
    cursor: pointer;
    border-radius: 2px;
    display: grid;
    grid-template-columns: 84px 1fr;
    overflow: hidden;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .pps__tab:hover,
  #shopify-section-{{ section.id }} .pps__tab.is-active {
    border-color: rgba(255, 255, 255, 0.35);
    background: rgba(255, 255, 255, 0.14);
  }

  #shopify-section-{{ section.id }} .pps__tab-thumb {
    min-height: 58px;
    background: #1f2230;
  }

  #shopify-section-{{ section.id }} .pps__tab-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .pps__tab-copy {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 12px;
    font-size: 1.2rem;
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .pps__training-media {
    position: relative;
    min-height: 320px;
  }

  #shopify-section-{{ section.id }} .pps__video-panel {
    display: none;
    height: 100%;
    min-height: 320px;
  }

  #shopify-section-{{ section.id }} .pps__video-panel.is-active {
    display: block;
  }

  #shopify-section-{{ section.id }} .pps__fitness {
    background: #232329;
  }

    #shopify-section-{{ section.id }} .pps__fitness img {
    height:350px;
  }


  #shopify-section-{{ section.id }} .pps__fitness-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .pps__fitness-card {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .pps__fitness-copy {
    margin-top: 12px;
  }

  #shopify-section-{{ section.id }} .pps__fitness-copy h3 {
    margin: 0 0 6px;
    color: #fff;
    font-size: 1.5rem;
  }

  #shopify-section-{{ section.id }} .pps__fitness-copy p {
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.25rem;
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .pps__pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  #shopify-section-{{ section.id }} .pps__pill {
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 1.1rem;
    line-height: 1.2;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  #shopify-section-{{ section.id }} .pps__app-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .pps__app-icons img {
    width: 24px;
    height: 24px;
    display: block;
  }

  #shopify-section-{{ section.id }} .pps__specs {
    background: #f2f2f4;
    color: #14161d;
  }

  #shopify-section-{{ section.id }} .pps__specs .pps__subtitle {
    color: #4a4d58;
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .pps__specs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.2fr;
    gap: 12px;
    margin-bottom: 24px;
    align-items: start;
  }

  #shopify-section-{{ section.id }} .pps__specs .pps__image-shell {
    background: #e6e7eb;
    border: 1px solid #d2d4da;
    color: #444957;
    min-height: 320px;
  }

  #shopify-section-{{ section.id }} .pps__spec-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  #shopify-section-{{ section.id }} .pps__spec-group h3 {
    margin: 0 0 10px;
    font-size: 1.8rem;
    line-height: 1.2;
    color: #14161d;
  }

  #shopify-section-{{ section.id }} .pps__spec-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid #d7d9df;
  }

  #shopify-section-{{ section.id }} .pps__spec-item {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid #d7d9df;
    font-size: 1.25rem;
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .pps__spec-item strong {
    font-weight: 700;
    color: #14161d;
  }

  #shopify-section-{{ section.id }} .pps__accordion {
    border-top: 1px solid #d7d9df;
  }

  #shopify-section-{{ section.id }} .pps__accordion-row {
    border-bottom: 1px solid #d7d9df;
  }

  #shopify-section-{{ section.id }} .pps__accordion-trigger {
    width: 100%;
    border: 0;
    background: transparent;
    padding: 15px 0;
    color: #14161d;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .pps__accordion-plus {
    font-size: 1.6rem;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .pps__accordion-trigger[aria-expanded='true'] .pps__accordion-plus {
    transform: rotate(45deg);
  }

  #shopify-section-{{ section.id }} .pps__accordion-content {
    display: none;
    padding: 0 0 14px;
    color: #343844;
    font-size: 1.22rem;
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .pps__accordion-content.is-open {
    display: block;
  }

  #shopify-section-{{ section.id }} .pps__jrny {
    background: #0b0c11;
  }

  #shopify-section-{{ section.id }} .pps__slider-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 18px;
  }

  #shopify-section-{{ section.id }} .pps__slider-nav {
    display: inline-flex;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .pps__arrow {
    width: 38px;
    height: 38px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
    cursor: pointer;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .pps__arrow[disabled] {
    opacity: 0.35;
    cursor: not-allowed;
  }

  #shopify-section-{{ section.id }} .pps__jrny-swiper {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .pps__jrny-swiper .swiper-wrapper {
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .pps__jrny-swiper .swiper-slide {
    height: auto;
  }

  #shopify-section-{{ section.id }} .pps__slide {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .pps__slide-image {
    aspect-ratio: 4 / 3;
    background: #1c1f2b;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .pps__slide h3 {
    margin: 0 0 4px;
    color: #fff;
    font-size: 2rem;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .pps__slide p {
    margin: 0;
    color: rgba(255, 255, 255, 0.84);
    font-size: 1.25rem;
    line-height: 1.45;
  }

  #shopify-section-{{ section.id }} .pps__dots {
    margin-top: 14px;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .pps__dots .swiper-pagination-bullet {
    width: 34px;
    height: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.26);
    opacity: 1;
  }

  #shopify-section-{{ section.id }} .pps__dots .swiper-pagination-bullet-active {
    background: #fff;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .pps__training,
    #shopify-section-{{ section.id }} .pps__fitness-grid,
    #shopify-section-{{ section.id }} .pps__specs-grid {
      grid-template-columns: 1fr;
    }

  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .pps__wrap {
      padding: 44px 16px;
    }

    #shopify-section-{{ section.id }} .pps__training-media,
    #shopify-section-{{ section.id }} .pps__video-panel {
      min-height: 220px;
    }

    #shopify-section-{{ section.id }} .pps__slider-head {
      align-items: flex-start;
      flex-direction: column;
    }

  }
{%- endstyle -%}

<div class="pps-sections" data-section-id="{{ section.id }}">
  {%- for index in (1..4) -%}
    {%- if section.settings.show_training and training_position == index -%}
      <section class="pps color-{{ section.settings.dark_color_scheme }}" data-section-id="{{ section.id }}">
        <div class="pps__wrap page-width">
          <h2 class="pps__title">{{ section.settings.training_heading }}</h2>
          <p class="pps__subtitle">{{ section.settings.training_subheading }}</p>

          <div class="pps__training" data-training-tabs>
            <div class="pps__training-tabs" role="tablist" aria-label="{{ section.settings.training_heading | escape }}">
              {%- if training_tabs.size > 0 -%}
                {%- for block in training_tabs -%}
                  <button
                    type="button"
                    class="pps__tab{% if forloop.first %} is-active{% endif %}"
                    role="tab"
                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                    aria-controls="pps-video-{{ section.id }}-{{ block.id }}"
                    id="pps-tab-{{ section.id }}-{{ block.id }}"
                    data-panel-id="pps-video-{{ section.id }}-{{ block.id }}"
                    {{ block.shopify_attributes }}
                  >
                    <span class="pps__tab-thumb">
                      {%- if block.settings.tab_thumbnail != blank -%}
                        {{ block.settings.tab_thumbnail | image_url: width: 220 | image_tag: loading: 'lazy', alt: block.settings.tab_title }}
                      {%- endif -%}
                    </span>
                    <span class="pps__tab-copy">{{ block.settings.tab_title }}</span>
                  </button>
                {%- endfor -%}
              {%- else -%}
                <button type="button" class="pps__tab is-active" role="tab" aria-selected="true" data-panel-id="pps-video-{{ section.id }}-fallback-1">
                  <span class="pps__tab-thumb">
                    {%- if section.settings.fallback_training_tab_image_1 != blank -%}
                      {{ section.settings.fallback_training_tab_image_1 | image_url: width: 220 | image_tag: loading: 'lazy', alt: section.settings.fallback_training_tab_title_1 }}
                    {%- endif -%}
                  </span>
                  <span class="pps__tab-copy">{{ section.settings.fallback_training_tab_title_1 }}</span>
                </button>
                <button type="button" class="pps__tab" role="tab" aria-selected="false" data-panel-id="pps-video-{{ section.id }}-fallback-2">
                  <span class="pps__tab-thumb">
                    {%- if section.settings.fallback_training_tab_image_2 != blank -%}
                      {{ section.settings.fallback_training_tab_image_2 | image_url: width: 220 | image_tag: loading: 'lazy', alt: section.settings.fallback_training_tab_title_2 }}
                    {%- endif -%}
                  </span>
                  <span class="pps__tab-copy">{{ section.settings.fallback_training_tab_title_2 }}</span>
                </button>
              {%- endif -%}
            </div>

            <div class="pps__training-media">
              {%- if training_tabs.size > 0 -%}
                {%- for block in training_tabs -%}
                  <div
                    class="pps__video-panel{% if forloop.first %} is-active{% endif %}"
                    id="pps-video-{{ section.id }}-{{ block.id }}"
                    role="tabpanel"
                    aria-labelledby="pps-tab-{{ section.id }}-{{ block.id }}"
                    {% unless forloop.first %}hidden{% endunless %}
                  >
                    <div class="pps__media-shell">
                      {%- if block.settings.video_embed_url != blank -%}
                        {%- if block.settings.video_embed_url contains '.mp4' -%}
                          <video controls playsinline preload="metadata">
                            <source src="{{ block.settings.video_embed_url }}" type="video/mp4">
                          </video>
                        {%- else -%}
                          <iframe
                            src="{{ block.settings.video_embed_url }}"
                            title="{{ block.settings.tab_title | escape }}"
                            loading="lazy"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen
                          ></iframe>
                        {%- endif -%}
                      {%- elsif block.settings.video_poster != blank -%}
                        {{ block.settings.video_poster | image_url: width: 1500 | image_tag: loading: 'lazy', alt: block.settings.tab_title }}
                      {%- else -%}
                        <video controls playsinline preload="metadata">
                          <source src="{{ fallback_training_video_url }}" type="video/mp4">
                        </video>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endfor -%}
              {%- else -%}
                <div class="pps__video-panel is-active" id="pps-video-{{ section.id }}-fallback-1" role="tabpanel">
                  <div class="pps__media-shell">
                    {%- if fallback_training_video_url != blank -%}
                      <video controls playsinline preload="metadata">
                        <source src="{{ fallback_training_video_url }}" type="video/mp4">
                      </video>
                    {%- else -%}
                      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                </div>
                <div class="pps__video-panel" id="pps-video-{{ section.id }}-fallback-2" role="tabpanel" hidden>
                  <div class="pps__media-shell">
                    {%- if fallback_training_video_url != blank -%}
                      <video controls playsinline preload="metadata">
                        <source src="{{ fallback_training_video_url }}" type="video/mp4">
                      </video>
                    {%- else -%}
                      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </section>
    {%- endif -%}

    {%- if section.settings.show_fitness and fitness_position == index -%}
      <section class="pps__fitness color-{{ section.settings.dark_color_scheme }}" data-section-id="{{ section.id }}">
        <div class="pps__wrap page-width">
          <h2 class="pps__title">{{ section.settings.fitness_heading }}</h2>
          <p class="pps__subtitle">{{ section.settings.fitness_subheading }}</p>

          <div class="pps__fitness-grid">
            <article class="pps__fitness-card">
              <div class="pps__image-shell">
                {%- if section.settings.fitness_left_image != blank -%}
                  {{ section.settings.fitness_left_image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: section.settings.fitness_left_title }}
                {%- else -%}
                  Fitness image
                {%- endif -%}
              </div>
              <div class="pps__fitness-copy">
                <h3>{{ section.settings.fitness_left_title }}</h3>
                <p>{{ section.settings.fitness_left_text }}</p>
                <div class="pps__pill-row">
                  <span class="pps__pill">{{ section.settings.fitness_left_pill_1 }}</span>
                  <span class="pps__pill">{{ section.settings.fitness_left_pill_2 }}</span>
                </div>
              </div>
            </article>

            <article class="pps__fitness-card">
              <div class="pps__image-shell">
                {%- if section.settings.fitness_right_image != blank -%}
                  {{ section.settings.fitness_right_image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: section.settings.fitness_right_title }}
                {%- else -%}
                  Touchscreen image
                {%- endif -%}
              </div>
              <div class="pps__fitness-copy">
                <h3>{{ section.settings.fitness_right_title }}</h3>
                <p>{{ section.settings.fitness_right_text }}</p>
                <div class="pps__app-icons">
                  {%- if app_icons.size > 0 -%}
                    {%- for block in app_icons -%}
                      {%- if block.settings.icon_image != blank -%}
                        {{ block.settings.icon_image | image_url: width: 48 | image_tag: loading: 'lazy', width: 24, height: 24, alt: block.settings.icon_alt }}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>
            </article>
          </div>
        </div>
      </section>
    {%- endif -%}

    {%- if section.settings.show_specs and specs_position == index -%}
      <section class="pps pps__specs color-{{ section.settings.light_color_scheme }}" data-section-id="{{ section.id }}">
        <div class="pps__wrap page-width">
          <h2 class="pps__title">{{ section.settings.specs_heading }}</h2>
          <p class="pps__subtitle">{{ section.settings.specs_subheading }}</p>

          <div class="pps__specs-grid">
            <div class="pps__image-shell">
              {%- if section.settings.spec_image_1 != blank -%}
                {{ section.settings.spec_image_1 | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.spec_image_1_alt }}
              {%- else -%}
                Open position image
              {%- endif -%}
            </div>
            <div class="pps__image-shell">
              {%- if section.settings.spec_image_2 != blank -%}
                {{ section.settings.spec_image_2 | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.spec_image_2_alt }}
              {%- else -%}
                Folded position image
              {%- endif -%}
            </div>

            <div class="pps__spec-columns">
              <div class="pps__spec-group">
                <h3>{{ section.settings.specs_group_heading }}</h3>
                <ul class="pps__spec-list">
                  {%- if spec_metrics.size > 0 -%}
                    {%- for block in spec_metrics -%}
                      <li class="pps__spec-item" {{ block.shopify_attributes }}>
                        <strong>{{ block.settings.label }}</strong>
                        <span>{{ block.settings.value }}</span>
                      </li>
                    {%- endfor -%}
                  {%- else -%}
                    <li class="pps__spec-item"><strong>Dimensions</strong><span>77.2” L × 35.2” W × 67.6” H</span></li>
                    <li class="pps__spec-item"><strong>Console</strong><span>16” HD Touchscreen</span></li>
                    <li class="pps__spec-item"><strong>Product Weight</strong><span>293 lbs</span></li>
                    <li class="pps__spec-item"><strong>Max User Weight</strong><span>375 lbs</span></li>
                  {%- endif -%}
                </ul>
              </div>

              <div class="pps__spec-group">
                <h3>{{ section.settings.warranty_group_heading }}</h3>
                <ul class="pps__spec-list">
                  {%- if warranty_metrics.size > 0 -%}
                    {%- for block in warranty_metrics -%}
                      <li class="pps__spec-item" {{ block.shopify_attributes }}>
                        <strong>{{ block.settings.label }}</strong>
                        <span>{{ block.settings.value }}</span>
                      </li>
                    {%- endfor -%}
                  {%- else -%}
                    <li class="pps__spec-item"><strong>Frame & Motor</strong><span>Lifetime</span></li>
                    <li class="pps__spec-item"><strong>Mechanical Parts</strong><span>3 Years</span></li>
                    <li class="pps__spec-item"><strong>Labor</strong><span>1 Year</span></li>
                  {%- endif -%}
                </ul>
              </div>
            </div>
          </div>

          <h3 class="pps__title" style="font-size:2.2rem; margin-bottom: 14px;">{{ section.settings.additional_specs_heading }}</h3>
          <div class="pps__accordion" data-accordion>
            {%- if accordion_rows.size > 0 -%}
              {%- for block in accordion_rows -%}
                <div class="pps__accordion-row" {{ block.shopify_attributes }}>
                  <button
                    class="pps__accordion-trigger"
                    type="button"
                    aria-expanded="false"
                    aria-controls="pps-accordion-{{ section.id }}-{{ block.id }}"
                    id="pps-accordion-trigger-{{ section.id }}-{{ block.id }}"
                  >
                    <span>{{ block.settings.title }}</span>
                    <span class="pps__accordion-plus">+</span>
                  </button>
                  <div class="pps__accordion-content" id="pps-accordion-{{ section.id }}-{{ block.id }}" role="region" aria-labelledby="pps-accordion-trigger-{{ section.id }}-{{ block.id }}">
                    {{ block.settings.content }}
                  </div>
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for item in fallback_accordion_titles -%}
                <div class="pps__accordion-row">
                  <button class="pps__accordion-trigger" type="button" aria-expanded="false">
                    <span>{{ item }}</span>
                    <span class="pps__accordion-plus">+</span>
                  </button>
                  <div class="pps__accordion-content">Add details from Theme Editor.</div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      </section>
    {%- endif -%}

    {%- if section.settings.show_membership and membership_position == index -%}
      <section class="pps pps__jrny color-{{ section.settings.dark_color_scheme }}" data-section-id="{{ section.id }}">
        <div class="pps__wrap page-width">
          <div class="pps__slider-head">
            <div>
              <h2 class="pps__title">{{ section.settings.membership_heading }}</h2>
              <p class="pps__subtitle">{{ section.settings.membership_subheading }}</p>
            </div>

            <div class="pps__slider-nav">
              <button class="pps__arrow pps__jrny-prev-{{ section.id }}" type="button" aria-label="Previous slide">‹</button>
              <button class="pps__arrow pps__jrny-next-{{ section.id }}" type="button" aria-label="Next slide">›</button>
            </div>
          </div>

          <div class="swiper pps__jrny-swiper pps__jrny-swiper-{{ section.id }}">
            <div class="swiper-wrapper">
              {%- if jrny_slides.size > 0 -%}
                {%- for block in jrny_slides -%}
                  <article class="swiper-slide pps__slide" {{ block.shopify_attributes }}>
                    <div class="pps__slide-image">
                      {%- if block.settings.image != blank -%}
                        {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
                      {%- elsif section.settings.jrny_default_image != blank -%}
                        {{ section.settings.jrny_default_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: block.settings.title }}
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </div>
                    <h3>{{ block.settings.title }}</h3>
                    <p>{{ block.settings.text }}</p>
                  </article>
                {%- endfor -%}
              {%- else -%}
                <article class="swiper-slide pps__slide">
                  <div class="pps__slide-image">
                    {%- if section.settings.jrny_default_image != blank -%}
                      {{ section.settings.jrny_default_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'JRNY slide image' }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <h3>Every day is different.</h3>
                  <p>Get adaptive workouts that keep your routine fresh.</p>
                </article>
                <article class="swiper-slide pps__slide">
                  <div class="pps__slide-image">
                    {%- if section.settings.jrny_default_image != blank -%}
                      {{ section.settings.jrny_default_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'JRNY slide image' }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <h3>Go ahead, pick up the pace.</h3>
                  <p>Virtual coaching provides guidance and encouragement.</p>
                </article>
                <article class="swiper-slide pps__slide">
                  <div class="pps__slide-image">
                    {%- if section.settings.jrny_default_image != blank -%}
                      {{ section.settings.jrny_default_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: 'JRNY slide image' }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <h3>Roam if you want.</h3>
                  <p>Explore the world while you train.</p>
                </article>
              {%- endif -%}
            </div>
          </div>

          <div class="pps__dots pps__jrny-pagination-{{ section.id }}"></div>
        </div>
      </section>
    {%- endif -%}
  {%- endfor -%}
</div>

<script>
  (() => {
    const sectionRoot = document.querySelector('#shopify-section-{{ section.id }}');
    if (!sectionRoot) return;

    const tabContainer = sectionRoot.querySelector('[data-training-tabs]');
    if (tabContainer) {
      const tabs = Array.from(tabContainer.querySelectorAll('.pps__tab'));
      const panels = Array.from(tabContainer.querySelectorAll('.pps__video-panel'));

      const activateTab = (tab) => {
        const targetId = tab.getAttribute('data-panel-id');

        tabs.forEach((currentTab) => {
          const isCurrent = currentTab === tab;
          currentTab.classList.toggle('is-active', isCurrent);
          currentTab.setAttribute('aria-selected', String(isCurrent));
        });

        panels.forEach((panel) => {
          const isCurrent = panel.id === targetId;
          panel.classList.toggle('is-active', isCurrent);
          panel.hidden = !isCurrent;
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => activateTab(tab));
      });
    }

    const accordion = sectionRoot.querySelector('[data-accordion]');
    if (accordion) {
      accordion.addEventListener('click', (event) => {
        const trigger = event.target.closest('.pps__accordion-trigger');
        if (!trigger) return;

        const row = trigger.closest('.pps__accordion-row');
        const content = row ? row.querySelector('.pps__accordion-content') : null;
        if (!content) return;

        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!isOpen));
        content.classList.toggle('is-open', !isOpen);
      });
    }

    const jrnySwiperSelector = `.pps__jrny-swiper-{{ section.id }}`;
    if (typeof Swiper !== 'undefined' && sectionRoot.querySelector(jrnySwiperSelector)) {
      new Swiper(jrnySwiperSelector, {
        slidesPerView: 1,
        spaceBetween: 12,
        loop: false,
        pagination: {
          el: `.pps__jrny-pagination-{{ section.id }}`,
          clickable: true
        },
        navigation: {
          nextEl: `.pps__jrny-next-{{ section.id }}`,
          prevEl: `.pps__jrny-prev-{{ section.id }}`
        },
        breakpoints: {
          750: {
            slidesPerView: 2
          },
          990: {
            slidesPerView: 3
          }
        }
      });
    }
  })();
</script>

