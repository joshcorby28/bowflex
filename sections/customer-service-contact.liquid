    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "header",
      "content": "Email block"
    },
    {
      "type": "text",
      "id": "email_label",
      "default": "Email",
      "label": "Email heading"
    },
    {
      "type": "text",
      "id": "email_link_1_label",
      "default": "Product Support",
      "label": "Link 1 label"
    },
    {
      "type": "url",
      "id": "email_link_1_url",
      "label": "Link 1 URL"
    },
    {
      "type": "text",
      "id": "email_link_2_label",
      "label": "Link 2 label"
    },
    {
      "type": "url",
      "id": "email_link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "email_note",
      "default": "Please allow up to 2 business days for a reply.",
      "label": "Note below links"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "contact_card",
      "name": "Contact card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "phone", "label": "Phone" },
            { "value": "email", "label": "Email" },
            { "value": "chat", "label": "Live chat" },
            { "value": "facebook", "label": "Facebook" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "support", "label": "Support" },
            { "value": "map", "label": "Map pin" },
            { "value": "clock", "label": "Clock" }
          ],
          "default": "phone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "General Sales"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Details",
          "default": "<p><a href=\"tel:01494412420\">01494 412420</a></p><p>Monday–Friday: 9 a.m.–5 p.m. GMT<br>Saturday &amp; Sunday: Closed</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Service Contact",
      "blocks": [
        {
          "type": "contact_card",
          "settings": {
            "icon": "phone",
            "title": "General Sales",
            "content": "<p><a href=\"tel:01494412420\">01494 412420</a></p><p>Monday–Friday: 9 a.m.–5 p.m. GMT<br>Saturday &amp; Sunday: Closed</p>"
          }
