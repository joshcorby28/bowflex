<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>

<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
/>

<section class="swiper-hero">
  <div class="swiper swiper-hero-slider">
    <div class="swiper-wrapper">

      {% for block in section.blocks %}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="slide-inner page-width">

            <div class="slide-content">
              {% if block.settings.badge != blank %}
                <div
                  class="badge"
                  style="background: {{ block.settings.badge_color }};"
                >
                  {{ block.settings.badge }}
                </div>
              {% endif %}

              {% if block.settings.heading != blank %}
                <h2>{{ block.settings.heading }}</h2>
              {% endif %}

              {% if block.settings.subtext != blank %}
                <p class="subtext">{{ block.settings.subtext }}</p>
              {% endif %}

              {% if block.settings.small_text != blank %}
                <p class="small-text">{{ block.settings.small_text }}</p>
              {% endif %}

              {% if block.settings.button_label != blank %}
                <a href="{{ block.settings.button_link }}" class="hero-btn">
                  {{ block.settings.button_label }}
                </a>
              {% endif %}
            </div>

            <div class="slide-image">
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | image_url: width: 1600 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                >
              {% endif %}
            </div>

          </div>
        </div>
      {% endfor %}

    </div>

<div class="swiper-controls">
      <button class="swiper-toggle" aria-label="Pause autoplay">
    <i class="fa-regular fa-circle-pause"></i>
  </button>
  <div class="swiper-pagination"></div>

</div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const swiper = new Swiper('.swiper-hero-slider', {
    loop: true,
    speed: 600,

    autoplay: {
      delay: 4000,
      disableOnInteraction: false,
    },

    pagination: {
      el: '.swiper-pagination',
      clickable: true,
    },

    navigation: {
      nextEl: '.swiper-button-next',
      prevEl: '.swiper-button-prev',
    },
  });

  const toggleBtn = document.querySelector('.swiper-toggle');
  const icon = toggleBtn.querySelector('i');

  toggleBtn.addEventListener('click', () => {
    if (swiper.autoplay.running) {
      swiper.autoplay.stop();

      icon.classList.remove('fa-circle-pause');
      icon.classList.add('fa-circle-play');
      toggleBtn.setAttribute('aria-label', 'Play autoplay');
    } else {
      swiper.autoplay.start();

      icon.classList.remove('fa-circle-play');
      icon.classList.add('fa-circle-pause');
      toggleBtn.setAttribute('aria-label', 'Pause autoplay');
    }
  });
});
</script>

<style>
  .swiper-hero {
    background: #000;
    color: #fff;
  }

  .swiper-hero .slide-inner {
    display: flex;
    min-height: 520px;
  }

  .slide-content {
    padding: 60px 60px 60px 120px; 
        padding-left: max(5rem, calc((100vw - var(--page-width) + 10rem - var(--grid-desktop-horizontal-spacing)) / 2));
  box-sizing: border-box; 
    display: flex;
    flex: 0 0 50%;
    flex-direction: column;
    justify-content: center;
  }

  .slide-image {
    lex: 0 0 50%;  
  }

  .slide-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge {
    display: inline-block;
    color: #000;
    padding: 6px 12px;
    border-radius: 999px;
    width:fit-content;
    font-size: 14px;
    margin-bottom: 20px;
    font-weight: 600;
  }

  h2 {
    font-size: 82px;
    margin: 0 0 20px;
    color: #fff;
  }

  .subtext {
    font-size: 2rem;
    margin-bottom: 10px;
    line-height: normal;
    color: #fff;
  }

  .small-text {
    margin-bottom: 25px;
    color: #fff;
  }

  .hero-btn {
    display: inline-block;
    background: #fff;
    color: #000;
    padding: 12px 22px;
    width:fit-content;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .slide-inner {
      flex-direction: column;
    }

    .slide-content {
      padding: 30px 20px;
    }

    h2 {
      font-size: 52px;
    }

    .slide-image {
      height: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "Swiper Hero Split",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Image" },

        { "type": "text", "id": "badge", "label": "Badge Text", "default": "New" },
        { "type": "color", "id": "badge_color", "label": "Badge Color", "default": "#b4ff63" },

        { "type": "text", "id": "heading", "label": "Heading", "default": "Upgrade your training" },
        { "type": "textarea", "id": "subtext", "label": "Sub Text", "default": "Promotional text goes here" },
        { "type": "text", "id": "small_text", "label": "Small Text", "default": "Limited time only" },

        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Now" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    { "name": "Swiper Hero Split" }
  ]
}
{% endschema %}