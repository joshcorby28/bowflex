{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .cg-wrap {
    text-align: center;
  }

  .cg-heading {
    margin-bottom: 1.2rem;
  }

  .cg-subtitle {
    font-size: 1.6rem;
    color: rgba(var(--color-foreground), 0.65);
    margin: 0 0 2.4rem;
  }

  .cg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2.4rem;
    text-align: left;
  }

  @media screen and (min-width: 750px) {
    .cg-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .cg-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  .cg-card {
    background: #f5f5f5;
    border-radius: 8px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .cg-card__badge {
    position: absolute;
    top: 1.6rem;
    right: 1.6rem;
    background: #6dd26d;
    color: #000;
    font-size: 1.2rem;
    font-weight: 600;
    padding: 0.3rem 1rem;
    border-radius: 20px;
  }

  .cg-card__image {
    display: block;
    margin-bottom: 1.6rem;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .cg-card__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .cg-card__title {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    display: block;
  }

  .cg-card__title:hover {
    text-decoration: underline;
  }

  .cg-card__subtitle {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 1.2rem;
  }

  .cg-card__offer {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #4041f1;
    font-size: 1.3rem;
    margin-bottom: 1.2rem;
  }

  .cg-card__price {
    margin-bottom: 1.6rem;
    margin-top: auto;
  }

  .cg-card__compare-price {
    text-decoration: line-through;
    color: rgba(var(--color-foreground), 0.5);
    font-size: 1.4rem;
    margin-right: 0.6rem;
  }

  .cg-card__price-current {
    color: #4041f1;
    font-size: 1.8rem;
    font-weight: 700;
  }

  .cg-card__btn {
    display: block;
    width: 100%;
    text-align: center;
    border: 1.5px solid rgb(var(--color-foreground));
    background: transparent;
    color: rgb(var(--color-foreground));
    padding: 1rem;
    font-size: 1.4rem;
    font-family: inherit;
    cursor: pointer;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.2s, color 0.2s;
    box-sizing: border-box;
  }

  .cg-card__btn:hover {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }

  .cg-view-all {
    display: flex;
    justify-content: center;
    margin-top: 0.8rem;
  }

  .cg-view-all__btn {
    display: inline-block;
    border: 1.5px solid rgba(var(--color-foreground), 0.2);
    background: #f5f5f5;
    color: rgb(var(--color-foreground));
    padding: 1rem 3.2rem;
    font-size: 1.4rem;
    font-family: inherit;
    text-decoration: none;
    border-radius: 4px;
    transition: border-color 0.2s;
  }

  .cg-view-all__btn:hover {
    border-color: rgb(var(--color-foreground));
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="cg-wrap">

      {%- if section.settings.heading != blank -%}
        <h2 class="cg-heading {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="cg-subtitle{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

      <div class="cg-grid">
        {%- if section.settings.collection != blank -%}
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            <div class="cg-card">

              {%- if product.tags contains 'new' or product.tags contains 'New' -%}
                <span class="cg-card__badge">New</span>
              {%- endif -%}

              <a href="{{ product.url }}" class="cg-card__image">
                {%- if product.featured_media -%}
                  {{
                    product.featured_media
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 800',
                      alt: product.featured_media.alt
                  }}
                {%- endif -%}
              </a>

              <a href="{{ product.url }}" class="cg-card__title">{{ product.title }}</a>

              {%- if product.metafields.custom.subtitle != blank -%}
                <p class="cg-card__subtitle">{{ product.metafields.custom.subtitle }}</p>
              {%- endif -%}

              {%- if product.compare_at_price > product.price -%}
                {%- assign saving = product.compare_at_price | minus: product.price -%}
                <div class="cg-card__offer">
                  <i class="bx bxs-purchase-tag"></i>
                  {{ saving | money }} Off + Free Delivery
                </div>
              {%- endif -%}

              <div class="cg-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="cg-card__compare-price">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
                <span class="cg-card__price-current">{{ product.price | money }}</span>
              </div>

              <a href="{{ product.url }}" class="cg-card__btn">Shop</a>

            </div>
          {%- else -%}
            <p style="opacity:0.5; grid-column: 1/-1;">No products found in this collection.</p>
          {%- endfor -%}
        {%- else -%}
          <p style="opacity:0.5; grid-column: 1/-1;">Select a collection in the theme editor.</p>
        {%- endif -%}
      </div>

      {%- if section.settings.show_view_all and section.settings.collection != blank -%}
        <div class="cg-view-all">
          <a href="{{ section.settings.collection.url }}" class="cg-view-all__btn">
            {{ section.settings.view_all_label | default: 'View All' }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Our Products",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Max products to show"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show 'View All' button"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "default": "View All",
      "label": "'View All' button label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}
