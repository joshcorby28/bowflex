<div class="utility-bar color-{{ section.settings.color_scheme }} gradient utility-bar--single-message">
  {%- if section.blocks.size > 0 and section.blocks.first.settings.text != blank -%}
    <div
      class="announcement-bar flex items-center justify-between"
      role="region"
      aria-label="{{ 'sections.header.announcement' | t }}"
      {{ section.blocks.first.shopify_attributes }}
    >
      <!-- Message -->
      <p class="announcement-bar__message h5 m-0">
        {{ section.blocks.first.settings.text | escape }}
      </p>

      <!-- Button if link exists -->
      {%- if section.blocks.first.settings.link != blank -%}
        <a
          href="{{ section.blocks.first.settings.link }}"
          class="global-black-button-small"
          role="button"
        >
           {{section.blocks.first.settings.button_text}}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 1,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "button link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Learn More"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}